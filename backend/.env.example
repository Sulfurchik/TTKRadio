# TransCom Stream - Environment Variables Example
# Copy this file to .env and update with your values

# Application
APP_NAME=TransCom Stream
APP_VERSION=1.0.0
DEBUG=False

# Database
# For SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./database.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://transcom:password@localhost:5432/transcom_stream

# Security - GENERATE YOUR OWN SECRET KEY!
# Use: openssl rand -hex 32
SECRET_KEY=your-secret-key-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEFAULT_ADMIN_LOGIN=admin
DEFAULT_ADMIN_PASSWORD=change-me-now
DEFAULT_ADMIN_FIO=Администратор Системы

# CORS - Update with your frontend URL
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Storage
MAX_AUDIO_SIZE_MB=50
MAX_VIDEO_SIZE_MB=1000
MAX_VOICE_MESSAGE_SIZE_MB=50
ALLOWED_AUDIO_FORMATS=["mp3","wav","ogg","webm","m4a"]
ALLOWED_VIDEO_FORMATS=["mp4","webm"]
STORAGE_PATH=./storage
